datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 1. ENTIDADES RELACIONAIS (CONFIGURAÇÃO)
// ==========================================

model Asset {
  id        String   @id @default(uuid())
  symbol    String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos para garantir integridade referencial
  scoreHistories      OracleScoreHistory[]
  marketDataSnapshots MarketDataSnapshot[]

  @@map("assets")
}

model OperatorConfig {
  id              String           @id @default(uuid())
  totalCapital    Float            // Capital alocado para cálculo de lote
  riskPerTradePct Float            @default(1.0) // Risco padrão por operação (ex: 1.0%)
  shieldStrictness ShieldStrictness @default(BALANCED)
  updatedAt       DateTime         @updatedAt

  @@map("operator_configs")
}

// ==========================================
// 2. ENTIDADES TIME-SERIES (SÉRIES TEMPORAIS)
// ==========================================

model OracleScoreHistory {
  timestamp    DateTime     @default(now())
  assetSymbol  String
  trendScore   Int
  volumeScore  Int
  momentumScore Int
  finalScore   Int
  confidence   Int
  shieldStatus ShieldStatus
  rationale    String       @db.Text

  // Relacionamento com o Ativo
  asset        Asset        @relation(fields: [assetSymbol], references: [symbol], onDelete: Cascade)

  // Índice composto para queries ultra rápidas ordenadas por tempo
  @@id([timestamp, assetSymbol])
  @@index([assetSymbol, timestamp(sort: Desc)])
  @@map("oracle_score_histories")
}

model MarketDataSnapshot {
  timestamp   DateTime @default(now())
  assetSymbol String
  price       Float
  volume      Float

  // Relacionamento com o Ativo
  asset       Asset    @relation(fields: [assetSymbol], references: [symbol], onDelete: Cascade)

  @@id([timestamp, assetSymbol])
  @@index([assetSymbol, timestamp(sort: Desc)])
  @@map("market_data_snapshots")
}

// ==========================================
// ENUMS
// ==========================================

enum ShieldStrictness {
  STRICT
  BALANCED
  PERMISSIVE
}

enum ShieldStatus {
  SAFE
  WARNING
  SHIELD_ACTIVE
}
